# ===============================
# Credenciais do portal Qualicorp
# ===============================
QUALICORP_URL=https://qualivendas.qualicorp.com.br/#/login
QUALICORP_USER=seu_email@exemplo.com
QUALICORP_PASSWORD=sua_senha

# ===============================
# Backend
# ===============================
BACKEND_PORT=3001

# Rodar o browser do Playwright em modo visivel (true) ou headless (false)
# Use 'true' durante desenvolvimento pra ver o que esta acontecendo
PLAYWRIGHT_HEADED=true

# Canal do browser: 'msedge' (usa o Edge instalado — recomendado no Windows),
# 'chrome' (Chrome instalado) ou vazio pra usar o Chromium baixado pelo Playwright.
PLAYWRIGHT_CHANNEL=msedge

# Diretorio da storage state do Playwright (cookies/session persistidos)
PLAYWRIGHT_STORAGE=./.playwright-session/state.json

# ===============================
# Frontend
# ===============================
VITE_BACKEND_URL=http://localhost:3001
